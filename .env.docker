# ============================================================
# InterviewLens · Docker 环境变量
# 使用方式：cp .env.docker .env 然后填入真实值
# 容器内服务通过 service name 互访，非 localhost
# ============================================================

# ---- Database ----
POSTGRES_USER=il
POSTGRES_PASSWORD=il_pass
POSTGRES_DB=interviewlens
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://il:il_pass@postgres:5432/interviewlens
DATABASE_URL_SYNC=postgresql+psycopg://il:il_pass@postgres:5432/interviewlens

# ---- Redis ----
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- LLM (DeepSeek) ----
DEEPSEEK_API_KEY=sk-REPLACE_ME
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_REASONER=deepseek-reasoner

# ---- Embedding (bge-m3, local CPU) ----
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=1024

# ---- Langfuse (self-hosted, 容器内通信用 langfuse:3000) ----
LANGFUSE_PORT=3001
LANGFUSE_PUBLIC_KEY=pk-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-REPLACE_ME
LANGFUSE_NEXTAUTH_SECRET=run_openssl_rand_hex_32_then_paste
LANGFUSE_SALT=run_openssl_rand_hex_32_then_paste

# ---- Nowcoder cookie ----
NOWCODER_COOKIE=
NOWCODER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# ---- Crawler tuning ----
CRAWLER_RATE_PER_SEC=1.5
CRAWLER_JITTER_MIN=2.0
CRAWLER_JITTER_MAX=5.0
CRAWLER_MAX_RETRIES=3

# ---- App ----
APP_ENV=prod
LOG_LEVEL=INFO
EXTRACT_PROMPT_VERSION=1
