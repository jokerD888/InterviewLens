# ============================================================
# InterviewLens · Environment configuration template
# Copy to .env and fill in real values. NEVER commit .env to git.
# ============================================================

# ---- Database ----
POSTGRES_USER=il
POSTGRES_PASSWORD=il_pass
POSTGRES_DB=interviewlens
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://il:il_pass@localhost:5433/interviewlens
DATABASE_URL_SYNC=postgresql+psycopg://il:il_pass@localhost:5433/interviewlens

# ---- Redis ----
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ---- LLM (DeepSeek) ----
DEEPSEEK_API_KEY=sk-REPLACE_ME
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_REASONER=deepseek-reasoner

# ---- Embedding (local, CPU-friendly) ----
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=1024

# ---- Langfuse (self-hosted) ----
LANGFUSE_PORT=3001
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-REPLACE_ME
LANGFUSE_NEXTAUTH_SECRET=run_openssl_rand_hex_32_then_paste
LANGFUSE_SALT=run_openssl_rand_hex_32_then_paste

# ---- Nowcoder cookie (login on web → DevTools → copy) ----
# Paste the entire Cookie header value as one line.
NOWCODER_COOKIE=
NOWCODER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# ---- Crawler tuning ----
CRAWLER_RATE_PER_SEC=1.5
CRAWLER_JITTER_MIN=2.0
CRAWLER_JITTER_MAX=5.0
CRAWLER_MAX_RETRIES=3

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO
EXTRACT_PROMPT_VERSION=1
